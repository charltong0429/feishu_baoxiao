# PostgreSQL Database URL
DATABASE_URL=postgresql://user:password@your-cloud-db-host:5432/reimbursement

# Feishu OAuth & Approval Settings
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APPROVAL_CODE=

# Encryption Secret (32 bytes base64 encoded)
ENCRYPT_SECRET=

# JWT Secret for token signing
JWT_SECRET=

# Server Port
PORT=3000
